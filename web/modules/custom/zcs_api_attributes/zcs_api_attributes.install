/**
 * Add auto increment ID to client_rate_sheet table.
 */
/**
 * Add the id column to client_rate_sheet and populate existing records.
 */
function zcs_api_attributes_update_9018() {
  $database = \Drupal::database();
  $schema = $database->schema();

  if (!$schema->tableExists('client_rate_sheet')) {
    return t('The client_rate_sheet table does not exist.');
  }

  // Add the column if it does not exist.
  if (!$schema->fieldExists('client_rate_sheet', 'id')) {
    $schema->addField('client_rate_sheet', 'id', [
      'type' => 'int',
      'unsigned' => TRUE,
      'not null' => FALSE,
      'description' => 'Temporary ID column.',
    ]);
  }

  // Populate only rows that do not yet have an ID.
  $result = $database->query("
    SELECT rate_sheet_id, client_id
    FROM {client_rate_sheet}
    WHERE id IS NULL
    ORDER BY created_date, rate_sheet_id, client_id
  ");

  $max_id = (int) $database->query("
    SELECT COALESCE(MAX(id), 0)
    FROM {client_rate_sheet}
  ")->fetchField();

  foreach ($result as $record) {
    $database->update('client_rate_sheet')
      ->fields([
        'id' => ++$max_id,
      ])
      ->condition('rate_sheet_id', $record->rate_sheet_id)
      ->condition('client_id', $record->client_id)
      ->execute();
  }

  return t('Added and populated the id column.');
}

/**
 * Converts client_rate_sheet.id to an auto increment primary key.
 */
/**
 * Convert client_rate_sheet.id into the AUTO_INCREMENT primary key.
 */
function zcs_api_attributes_update_9019() {
  $database = \Drupal::database();
  $schema = $database->schema();

  if (!$schema->tableExists('client_rate_sheet')) {
    return t('The client_rate_sheet table does not exist.');
  }

  // Ensure there are no NULL IDs.
  $null_count = (int) $database->query("
    SELECT COUNT(*)
    FROM {client_rate_sheet}
    WHERE id IS NULL
  ")->fetchField();

  if ($null_count > 0) {
    throw new \Drupal\Core\Utility\UpdateException('Some records still have NULL IDs.');
  }

  // Check whether id is already AUTO_INCREMENT.
  $extra = $database->query("
    SELECT EXTRA
    FROM information_schema.COLUMNS
    WHERE TABLE_SCHEMA = DATABASE()
      AND TABLE_NAME = 'client_rate_sheet'
      AND COLUMN_NAME = 'id'
  ")->fetchField();

  if ($extra === 'auto_increment') {
    return t('The id column is already AUTO_INCREMENT.');
  }

  // Remove the current composite primary key.
  $database->query("
    ALTER TABLE {client_rate_sheet}
    DROP PRIMARY KEY
  ");

  // Convert id into AUTO_INCREMENT and PRIMARY KEY.
  $database->query("
    ALTER TABLE {client_rate_sheet}
      MODIFY COLUMN id INT UNSIGNED NOT NULL AUTO_INCREMENT,
      ADD PRIMARY KEY (id)
  ");

  // Preserve uniqueness of the original business key.
  $database->query("
    ALTER TABLE {client_rate_sheet}
      ADD UNIQUE KEY client_rate_sheet_unique (rate_sheet_id, client_id)
  ");

  return t('Converted id to AUTO_INCREMENT primary key.');
}

/**
 * Create the api_access_token table.
 */
function zcs_api_attributes_update_9020() {
  $schema = Database::getConnection()->schema();
  
  if ($schema->tableExists('api_access_token')) {
    return t('Table api_access_token already exists.');
  }

  $table_schema = [
    'description' => 'Stores API access tokens for client authentication.',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'not null' => TRUE,
        'description' => 'Primary Key: Unique token ID.',
      ],
      'client_id' => [
        'type' => 'int',
        'not null' => TRUE,
        'description' => 'The client (Group) ID this token belongs to.',
      ],
      'name' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'description' => 'Human-readable token name.',
      ],
      'token_prefix' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'description' => 'Public token prefix for lookup.',
      ],
      'token_hash' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'description' => 'Secure hash of the token secret.',
      ],
      'expires_at' => [
        'type' => 'int',
        'not null' => FALSE,
        'description' => 'Expiration timestamp. NULL means no expiration.',
      ],
      'last_used' => [
        'type' => 'int',
        'not null' => FALSE,
        'description' => 'Timestamp of last successful token usage.',
      ],
      'last_used_ip' => [
        'type' => 'varchar',
        'length' => 128,
        'not null' => FALSE,
        'description' => 'IP address from last successful token usage.',
      ],
      'last_used_user_agent' => [
        'type' => 'text',
        'not null' => FALSE,
        'description' => 'User-Agent from last successful token usage.',
      ],
      'active' => [
        'type' => 'int',
        'size' => 'tiny',
        'not null' => TRUE,
        'default' => 1,
        'description' => 'Boolean indicating whether the token is active.',
      ],
      'created_by' => [
        'type' => 'int',
        'not null' => TRUE,
        'description' => 'User ID of the admin who created the token.',
      ],
      'created_date' => [
        'type' => 'int',
        'not null' => TRUE,
        'description' => 'Creation timestamp.',
      ],
      'changed_by' => [
        'type' => 'int',
        'not null' => FALSE,
        'description' => 'User ID of the admin who last changed the token.',
      ],
      'changed_date' => [
        'type' => 'int',
        'not null' => FALSE,
        'description' => 'Last changed timestamp.',
      ],
      'revoked_by' => [
        'type' => 'int',
        'not null' => FALSE,
        'description' => 'User ID of the admin who revoked the token.',
      ],
      'revoked_date' => [
        'type' => 'int',
        'not null' => FALSE,
        'description' => 'Revocation timestamp.',
      ],
    ],
    'primary key' => ['id'],
    'unique keys' => [
      'token_prefix' => ['token_prefix'],
    ],
    'indexes' => [
      'client_id' => ['client_id'],
      'active' => ['active'],
      'expires_at' => ['expires_at'],
    ],
  ];

  $schema->createTable('api_access_token', $table_schema);
  
  return t('Created api_access_token table.');
}

