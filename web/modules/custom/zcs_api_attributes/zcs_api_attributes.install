/**
 * Adding new tables to add the new client/ratesheet structure.
 */
function zcs_api_attributes_update_9012() {
  $tables = [];

  /**
   * Rate Sheet
   */
  $tables['rate_sheet'] = [
    'description' => 'Stores rate sheets.',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'not null' => TRUE,
      ],
      'name' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => '',
      ],
      'currency' => [
        'type' => 'varchar',
        'length' => 45,
        'not null' => FALSE,
        'default' => '',
      ],
      'effective_date' => [
        'type' => 'varchar',
        'length' => 10,
        'not null' => FALSE,
        'default' => '',
      ],
      'markup_retail' => [
        'type' => 'float',
        'not null' => FALSE,
        'default' => 0,
      ],
      'created_by' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
      ],
      'created_date' => [
        'type' => 'varchar',
        'length' => 19,
        'not null' => FALSE,
        'default' => '',
      ],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'created_by' => ['created_by'],
    ],
    'foreign keys' => [
      'rate_sheet_author' => [
        'table' => 'users',
        'columns' => [
          'created_by' => 'uid',
        ],
      ],
    ],
  ];

  /**
   * Rate Sheet Item
   * api_attribute_id references node.nid
   * content type: api_attributes
   */
  $tables['rate_sheet_item'] = [
    'description' => 'Stores rate sheet items.',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'not null' => TRUE,
      ],
      'attribute_name' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => FALSE,
        'default' => '',
        'description' => 'Attribute name.',
      ],
      'rate_sheet_id' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
      ],
      'api_attribute_id' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Reference to node.nid where bundle = api_attributes.',
      ],
      'tiered_calculation' => [
        'type' => 'int',
        'size' => 'tiny',
        'unsigned' => TRUE,
        'default' => 0,
      ],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'rate_sheet_id' => ['rate_sheet_id'],
      'api_attribute_id' => ['api_attribute_id'],
    ],
    'foreign keys' => [
      'rate_sheet_ref' => [
        'table' => 'rate_sheet',
        'columns' => [
          'rate_sheet_id' => 'id',
        ],
      ],
      'api_attribute_node_ref' => [
        'table' => 'node',
        'columns' => [
          'api_attribute_id' => 'nid',
        ],
      ],
    ],
  ];

  $tables['rate_sheet_item_range'] = [
    'description' => 'Stores rate sheet items ranges.',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'not null' => TRUE,
      ],
      'rate_sheet_item_id' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
      ],
      'from_range' => [
        'type' => 'float',
        'default' => 0,
      ],
      'to_range' => [
        'type' => 'float',
        'default' => 0,
      ],
      'success_rate' => [
        'type' => 'float',
        'default' => 0,
      ],
      'partial_range' => [
        'type' => 'float',
        'default' => 0,
      ],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'rate_sheet_item_id' => ['rate_sheet_item_id'],
    ],
    'foreign keys' => [
      'rate_sheet_item_ref' => [
        'table' => 'rate_sheet_item',
        'columns' => [
          'rate_sheet_item_id' => 'id',
        ],
      ],
    ],
  ];

  /**
   * Client Rate Sheet
   * client_id references groups.id
   */
  $tables['client_rate_sheet'] = [
    'description' => 'Relationship between clients and rate sheets.',
    'fields' => [
      'rate_sheet_id' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'client_id' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'created_by' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'created_date' => [
        'type' => 'varchar',
        'length' => 19,
        'default' => '',
      ],
      'active' => [
        'type' => 'int',
        'size' => 'tiny',
        'unsigned' => TRUE,
        'default' => 0,
      ],
    ],
    'primary key' => ['rate_sheet_id', 'client_id'],
    'indexes' => [
      'client_id' => ['client_id'],
      'created_by' => ['created_by'],
    ],
    'foreign keys' => [
      'rate_sheet_ref' => [
        'table' => 'rate_sheet',
        'columns' => [
          'rate_sheet_id' => 'id',
        ],
      ],

      'partner_group_ref' => [
        'table' => 'groups',
        'columns' => [
          'client_id' => 'id',
        ],
      ],

      'author_ref' => [
        'table' => 'users',
        'columns' => [
          'created_by' => 'uid',
        ],
      ],
    ],
  ];

  /**
   * Action Log
   */
  $tables['action_log'] = [
    'description' => 'Stores audit/action logs.',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'not null' => TRUE,
      ],
      'action_type' => [
        'type' => 'varchar',
        'length' => 45,
        'default' => '',
      ],
      'entity_target_type' => [
        'type' => 'varchar',
        'length' => 45,
        'default' => '',
      ],
      'entity_target_id' => [
        'type' => 'int',
        'default' => 0,
      ],
      'created_by' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
      ],
      'created_date' => [
        'type' => 'varchar',
        'length' => 19,
        'default' => '',
      ],
      'log_data' => [
        'type' => 'text',
        'size' => 'big',
        'serialize' => TRUE,
      ],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'created_by' => ['created_by'],
    ],
  ];

  $tables['rate_sheet_status'] = [
    'description' => 'Relationship between rate sheets and statuses.',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'not null' => TRUE,
      ],
      'rate_sheet_id' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'status_name' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => '',
      ],
      'date' => [
        'type' => 'varchar',
        'length' => 10,
        'not null' => FALSE,
        'default' => '',
      ],
      'created_by' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'rate_sheet_id' => ['rate_sheet_id'],
      'created_by' => ['created_by']
    ],
    'foreign keys' => [
      'author_ref' => [
        'table' => 'users',
        'columns' => [
          'created_by' => 'uid',
        ],
      ],
    ],
  ];

  $schema = \Drupal::database()->schema();

  foreach ($tables as $table_name => $table) {
    if (!$schema->tableExists($table_name)) {
      $schema->createTable($table_name, $table);
    }
  }
}

/**
 * Create rate_sheet_status_lookup table and add status field to rate_sheet.
 */
function zcs_api_attributes_update_9014() {
  $schema = \Drupal::database()->schema();
  $database = \Drupal::database();

  // Create rate_sheet_status table if it doesn't exist.
  if (!$schema->tableExists('rate_sheet_status_lookup')) {
    $table = [
      'description' => 'Lookup table for rate sheet statuses.',
      'fields' => [
        'id' => [
          'type' => 'serial',
          'not null' => TRUE,
          'description' => 'Primary Key: Unique status ID.',
        ],
        'status_name' => [
          'type' => 'varchar',
          'length' => 255,
          'not null' => TRUE,
          'default' => '',
          'description' => 'Status name.',
        ],
      ],
      'primary key' => ['id'],
      'unique keys' => [
        'status_name' => ['status_name'],
      ],
    ];
    $schema->createTable('rate_sheet_status_lookup', $table);

    // Pre-populate with default statuses.
    $database->insert('rate_sheet_status_lookup')
      ->fields(['status_name'])
      ->values(['Pending'])
      ->values(['Approved'])
      ->values(['Draft'])
      ->values(['Rejected'])
      ->values(['Cancelled'])
      ->execute();
  }

  // Add rate_sheet_status_id field to rate_sheet table if it doesn't exist.
  if ($schema->tableExists('rate_sheet') && !$schema->fieldExists('rate_sheet', 'rate_sheet_status_id')) {
    $spec = [
      'type' => 'int',
      'unsigned' => TRUE,
      'not null' => FALSE,
      'default' => NULL,
      'description' => 'Foreign key to rate_sheet_status_lookup.id',
    ];
    $schema->addField('rate_sheet', 'rate_sheet_status_id', $spec);

    // Add index for the foreign key.
    $schema->addIndex('rate_sheet', 'rate_sheet_status_id', ['rate_sheet_status_id'], [
      'fields' => [
        'rate_sheet_status_id' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => FALSE,
        ],
      ],
    ]);
  }
}

