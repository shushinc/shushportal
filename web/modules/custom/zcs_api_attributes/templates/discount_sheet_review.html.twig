{{ form.form_build_id }}
{{ form.form_token }}
{{ form.form_id }}

<div class="rate-sheet-filter">
  <div class="rate-sheet-filter-currencies">
    <span class="attributes-label">Currency</span>
    <span class="attribute-inputs">{{ form.currencies }}</span>
  </div>
  <div class="rate-sheet-filter-effective">
    <span class="attributes-label">Client Name</span>
    <span class="attribute-inputs">{{ form.client }}</span>
  </div>  
</div>
<table class="attributes-table">
  <thead>
    <tr>
      <th>#</th>
      <th>API Attributes</th>
      <th>Proposed Discount Pricing</th>
    </tr>
  </thead>
  <tbody>
    {% set counter = 1 %}
    {% set attributes = fetch_attributes() %}
    {% for id, title in attributes.titles %}
      <tr>
        <td>{{ counter }}</td>
        <td>{{ title }}</td>
        <td>
           {{ form['discount_price_' ~ id] }} 
        </td>
      </tr>
      {% set counter = counter + 1 %}
    {% endfor %}
  </tbody>
</table>

{{ form.status }}
{{ form.approve }}
{{ form.reject }}
