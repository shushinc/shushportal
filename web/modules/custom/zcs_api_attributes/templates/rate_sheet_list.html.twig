{{ attach_library('core/drupal.dialog.ajax') }}
  <div>
    <div class="user-management-view api-attribute-status-header">
      <header>
        {{ content.link|merge({'#attributes': {'class': ['btn-primary']}}) }}
      </header>
    </div>
    <table class="attributes-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Currency</th>
          <th>Effec. Date</th>
          <th>Markup Retail(%)</th>
          <th>Approvers</th>
          <th>Status</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        {% set counter = 1 %}
        {% for sheet_info in content.final %}

          {% set rate_sheet_status = sheet_info.status|lower %}

          <tr>
            <td>{{ counter }}</td>
            <td>{{ sheet_info.name }}</td>
            <td>{{ sheet_info.currency }}</td>
            <td>{{ sheet_info.effective_date }}</td>
            <td>{{ sheet_info.markup_retail }}</td>
            <td>{{ sheet_info.approvals|raw }}</td>
            <td class="{{ rate_sheet_status }}">{{ sheet_info.status }}</td>
            <td>
              <div class="dropdown">
                <button class="btn btn-sm btn-primary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                  Actions
                </button>

                <ul class="dropdown-menu dropdown-menu-end">
                  {% for action in sheet_info.actions %}
                    <li>
                      <a
                        href="{{ action.disabled ? 'javascript:void(0)' : action.url }}"
                        class="dropdown-item {{ action.class }} {% if action.ajax %}use-ajax{% endif %}"
                        {% if action.ajax %}
                          data-dialog-type="modal"
                          data-dialog-options='{"width":1000,"title":"Rate Sheet Review","dialogClass":"api-popup-width-resize api-table-fixed"}'
                        {% endif %}
                      >
                        {{ action.title }}
                      </a>
                    </li>
                  {% endfor %}
                </ul>
              </div>
            </td>
          </tr>
          {% set counter = counter + 1 %}
        {% endfor %}

      </tbody>
    </table>
  </div>
