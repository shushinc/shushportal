<div>
  <div class="user-management-view api-attribute-status-header">
    <header>
      {{ content.link|merge({'#attributes': {'class': ['btn-primary']}}) }}
    </header>
  </div>
  <table class="attributes-table">
    <thead>
      <tr>
        <th>#</th>
        <th>Name</th>
        <th>Currency</th>
        <th>Effec. Date</th>
        <th>Markup Retail(%)</th>
      </tr>
    </thead>
    <tbody>
      {% set counter = 1 %}
      {% for key, att in content.final %}
        <tr>
          <td>{{ counter }}</td>
          <td>{{ counter }}</td>
          <td>{{ counter }}</td>
          <td>{{ counter }}</td>
          <td>{{ counter }}</td>
        </tr>
        {% set counter = counter + 1 %}
      {% endfor %}

    </tbody>
  </table>
</div>
